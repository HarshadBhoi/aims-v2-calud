{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "./.next/types",
    "rootDir": ".",
    "baseUrl": ".",
    "paths": {
      "@/*": ["./*"]
    },
    "jsx": "preserve",
    "lib": ["DOM", "DOM.Iterable", "ES2023"],
    "types": ["node"],
    "allowJs": true,
    "checkJs": false,
    "noEmit": true,
    "composite": false,
    "incremental": true,
    "declaration": false,
    "declarationMap": false,
    "sourceMap": true,
    "plugins": [{ "name": "next" }]
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts"
  ],
  "exclude": ["node_modules", ".next", "dist", ".tsbuildinfo"]
}
