{
  "name": "@aims/web",
  "version": "0.0.1",
  "private": true,
  "description": "Next.js 15 frontend — App Router + Tailwind v4 + Shadcn/ui base.",
  "type": "module",
  "scripts": {
    "dev": "next dev --turbopack --port 3000",
    "build": "next build",
    "start": "next start --port 3000",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "test": "echo \"(unit tests intentionally minimal here — see e2e for journey coverage)\" && exit 0",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "clean": "rm -rf .next .tsbuildinfo"
  },
  "dependencies": {
    "@aims/api": "workspace:*",
    "@aims/validation": "workspace:*",
    "@tanstack/react-query": "^5.59.16",
    "@trpc/client": "^11.0.0-rc.593",
    "@trpc/react-query": "^11.0.0-rc.593",
    "@trpc/server": "^11.0.0-rc.593",
    "next": "^15.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "superjson": "^2.2.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@aims/encryption": "workspace:*",
    "@aims/prisma-client": "workspace:*",
    "@aws-sdk/client-kms": "^3.658.0",
    "@node-rs/argon2": "^2.0.2",
    "@playwright/test": "^1.48.0",
    "@tailwindcss/postcss": "^4.0.0-alpha.31",
    "@types/node": "^22.7.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "eslint-config-next": "^15.0.0",
    "otplib": "^12.0.1",
    "postcss": "^8.4.47",
    "tailwindcss": "^4.0.0-alpha.31"
  }
}
