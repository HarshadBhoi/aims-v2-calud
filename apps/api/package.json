{
  "name": "@aims/api",
  "version": "0.0.1",
  "private": true,
  "description": "Fastify + tRPC hot-path API (ADR-0003). NestJS lives in apps/worker, NOT here.",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -b",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rm -rf dist .tsbuildinfo",
    "set-password": "tsx src/cli/set-password.ts"
  },
  "dependencies": {
    "@aims/encryption": "workspace:*",
    "@aims/prisma-client": "workspace:*",
    "@aims/validation": "workspace:*",
    "@aws-sdk/client-kms": "^3.658.0",
    "@fastify/cookie": "^11.0.1",
    "@fastify/cors": "^10.0.1",
    "@fastify/helmet": "^12.0.1",
    "@fastify/sensible": "^6.0.1",
    "@node-rs/argon2": "^2.0.2",
    "@trpc/server": "^11.0.0-rc.593",
    "fastify": "^5.0.0",
    "jose": "^5.9.6",
    "otplib": "^12.0.1",
    "pino": "^9.4.0",
    "superjson": "^2.2.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@testcontainers/postgresql": "^10.13.2",
    "@types/node": "^22.7.0",
    "testcontainers": "^10.13.2",
    "vitest": "^2.1.3"
  }
}
