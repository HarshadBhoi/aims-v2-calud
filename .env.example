# AIMS v2 — Environment variables (development defaults)
#
# Copy to .env.local at repo root and source in each app as needed.
# .env.local is gitignored. Never commit real secrets.

# ─── Runtime ─────────────────────────────────────────────────────────────────
NODE_ENV=development
LOG_LEVEL=debug

# ─── Ports ───────────────────────────────────────────────────────────────────
WEB_PORT=3000
API_PORT=3001
# (worker is headless — no port)

# ─── Database ────────────────────────────────────────────────────────────────
# Application runtime: uses aims_app role, RLS enforced.
DATABASE_URL=postgresql://aims_app:dev_app_password@localhost:5433/aims_dev?schema=public

# Migrations: uses aims_migration role, bypasses RLS for DDL + seed.
DATABASE_MIGRATION_URL=postgresql://aims_migration:dev_migration_password@localhost:5433/aims_dev?schema=public

# Admin client (api + worker): uses aims_migration so cross-tenant ops
# (auth's tenant lookup, audit-log chain verify, worker outbox draining)
# bypass RLS. Per ADR-0002. The tenant client (DATABASE_URL above) stays
# RLS-bound — defense-in-depth on top of the Prisma extension.
DATABASE_ADMIN_URL=postgresql://aims_migration:dev_migration_password@localhost:5433/aims_dev?schema=public

# Read-only: analytics, support-mode (future).
DATABASE_READONLY_URL=postgresql://aims_readonly:dev_readonly_password@localhost:5433/aims_dev?schema=public

# ─── AWS (LocalStack in dev) ─────────────────────────────────────────────────
AWS_REGION=us-east-1
AWS_ENDPOINT_URL=http://localhost:4566
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test

# KMS (ADR-0001: ALE with per-tenant DEKs wrapped by this master KEK).
AWS_KMS_MASTER_KEY_ALIAS=alias/aims-dev-master

# SQS (ADR-0004: worker-tier queuing).
SQS_OUTBOX_URL=http://localhost:4566/000000000000/aims-events-outbox
SQS_OUTBOX_DLQ_URL=http://localhost:4566/000000000000/aims-events-outbox-dlq
SQS_PDF_RENDER_URL=http://localhost:4566/000000000000/aims-pdf-render
SQS_PDF_RENDER_DLQ_URL=http://localhost:4566/000000000000/aims-pdf-render-dlq

# S3 (evidence uploads, rendered reports, archived audit logs).
S3_EVIDENCE_BUCKET=aims-dev-evidence
S3_REPORTS_BUCKET=aims-dev-reports
S3_AUDIT_LOGS_BUCKET=aims-dev-audit-logs

# ─── Redis (ADR-0005: session blocklist cache) ───────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── SMTP (mailpit in dev — view UI at http://localhost:8025) ────────────────
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_FROM="AIMS Dev <no-reply@aims.local>"

# ─── Auth secrets ────────────────────────────────────────────────────────────
# Real JWT keys are generated via Better Auth; for dev these are fine as-is.
# DO NOT USE THESE VALUES IN ANY SHARED OR DEPLOYED ENVIRONMENT.
AUTH_JWT_PRIVATE_KEY_DEV="dev-ed25519-private-key-placeholder-regenerate-in-task-2.1"
AUTH_SESSION_COOKIE_DOMAIN=localhost
AUTH_MFA_ISSUER="AIMS Dev"

# ─── CORS ────────────────────────────────────────────────────────────────────
CORS_ORIGIN=http://localhost:3000
