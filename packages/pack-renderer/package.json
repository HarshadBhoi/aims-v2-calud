{
  "name": "@aims/pack-renderer",
  "version": "0.0.1",
  "private": true,
  "description": "Cross-pack finding renderer — translates a canonical-keyed finding into rows formatted under a target pack's vocabulary, honoring equivalenceStrength.",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "build": "tsc -b",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rm -rf dist .tsbuildinfo"
  },
  "dependencies": {},
  "devDependencies": {
    "vitest": "^2.1.3"
  }
}
