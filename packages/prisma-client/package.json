{
  "name": "@aims/prisma-client",
  "version": "0.0.1",
  "private": true,
  "description": "Tenant-isolated Prisma client with two-layer enforcement (ADR-0002). Schema + migrations live here.",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "build": "tsc -b",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "test": "echo \"(tests added in Task 1.4 — tenant isolation integration test)\" && exit 0",
    "clean": "rm -rf dist .tsbuildinfo",

    "db:generate": "prisma generate",
    "db:migrate:dev": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:migrate:reset": "prisma migrate reset",
    "db:push": "prisma db push",
    "db:studio": "prisma studio",
    "db:format": "prisma format"
  },
  "dependencies": {
    "@prisma/client": "^5.20.0"
  },
  "devDependencies": {
    "prisma": "^5.20.0"
  }
}
