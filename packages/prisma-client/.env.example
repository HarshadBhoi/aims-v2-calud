# Prisma CLI env file — for migrations, studio, generate.
#
# Prisma CLI reads DATABASE_URL from the nearest .env when run.
# Our app code reads a DIFFERENT DATABASE_URL at runtime (aims_app role, RLS
# active). The CLI needs the aims_migration role which can create schemas
# and bypass RLS for DDL.
#
# Copy to .env (gitignored) locally:
#   cp .env.example .env
#
# NOTE: these are dev credentials only. Never commit a real .env.
DATABASE_URL="postgresql://aims_migration:dev_migration_password@localhost:5433/aims_dev?schema=public"
